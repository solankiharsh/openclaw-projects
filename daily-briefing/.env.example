# GitHub personal access token (repo scope)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Path to Google Cloud service account JSON key file
GOOGLE_SERVICE_ACCOUNT_JSON=./service-account.json

# ClickUp personal API token
CLICKUP_API_TOKEN=pk_xxxxxxxx

# Path to Gmail OAuth credentials JSON (or service account with domain delegation)
GMAIL_CREDENTIALS_JSON=./gmail-credentials.json

# Telegram bot token and chat ID for delivery
TELEGRAM_BOT_TOKEN=123456:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=123456789
